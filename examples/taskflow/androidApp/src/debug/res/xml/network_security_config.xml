<?xml version="1.0" encoding="utf-8"?>
<!--
  Redux DevTools talks to the desktop server over plain ws:// (cleartext), which
  Android blocks by default on API 28+. Permit cleartext only to the loopback
  hosts used for local debugging: 10.0.2.2 (emulator -> host) and localhost
  (USB device with `adb reverse tcp:8000 tcp:8000`). Debug convenience only.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>
